{
  "name": "@algosail/tree-sitter",
  "version": "0.2.1",
  "description": "Tree-sitter grammar for the Sail language",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "build:wasm": "tree-sitter build --wasm",
    "build:native": "node-gyp rebuild",
    "generate": "tree-sitter generate",
    "install": "echo 'Skipping native build. Run npm run build:native manually if needed.'",
    "playground": "tree-sitter playground"
  },
  "devDependencies": {
    "node-addon-api": "^8.6.0",
    "tree-sitter-cli": "^0.26.7"
  },
  "tree-sitter": [
    {
      "scope": "source.sail",
      "file-types": [
        "sail"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "author": "algosail",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/algosail/tree-sitter.git"
  },
  "bugs": {
    "url": "https://github.com/algosail/tree-sitter/issues"
  },
  "homepage": "https://github.com/algosail/tree-sitter#readme",
  "license": "MIT",
  "files": [
    "grammar.js",
    "queries/*",
    "src/**",
    "*.wasm"
  ]
}
